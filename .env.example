# ─────────────────────────────────────────────────────────────
# WhatsApp Expense Agent — environment variables
# Copy this file to ".env" and fill in the values.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string (local / Supabase / Neon / Railway ...)
# Example (local): postgresql://postgres:postgres@localhost:5432/whatsapp_expenses?schema=public
DATABASE_URL=

# OpenAI API key — OPTIONAL.
# If empty, the system falls back to a local regex-based expense extractor.
OPENAI_API_KEY=

# OpenAI model used for text extraction (optional, has a sane default)
OPENAI_TEXT_MODEL=gpt-4o-mini
# OpenAI model used for image / receipt vision (optional)
OPENAI_VISION_MODEL=gpt-4o-mini

# The owner's phone number in international format, digits only, no "+".
# This number becomes the family OWNER on seed.
OWNER_PHONE=972501234567

# Initial family created by the seed script
DEFAULT_FAMILY_NAME=משפחת Levy
DEFAULT_INVITE_CODE=ABC123

# Default currency for the seeded family
DEFAULT_CURRENCY=ILS

# Where uploaded receipts/invoices are stored (relative to project root)
UPLOADS_DIR=uploads

# Directory where the Baileys WhatsApp auth session is persisted
WHATSAPP_AUTH_DIR=auth

# ───────────── Dashboard login ─────────────
# The ADMIN account is defined here (not in the DB). Additional dashboard
# users can be created from inside the dashboard once logged in as admin.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Secret used to sign login session cookies — set to a long random string.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=
# Days a login stays valid before the password is required again.
SESSION_DAYS=7
